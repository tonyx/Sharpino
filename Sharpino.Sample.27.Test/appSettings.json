{
  "IsTestEnv": true,
  "CancellationTokenSourceExpiration": 100000,
  "EventStoreTimeout": 10000,
  "PgSqlJsonFormat": "PlainText",
  "MailBoxCommandProcessorsSize": 100,
  "DetailsCacheExpiration": 300,
